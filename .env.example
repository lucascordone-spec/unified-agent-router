# Unified Agent Router - Example Environment Variables
# Copy this file to .env and fill in your real keys

# The wallet address where the 0.02% fee will be sent (EVM compatible)
FEE_WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# Aggregator API Keys
ONEINCH_API_KEY=your_1inch_key_here

# Wallet Authentication
# Your Metamask private key for EVM chains (DO NOT share this in public repos)
METAMASK_PRIVATE_KEY=your_private_key_here
# Your Solana public address for Jupiter (Solana) routes
SOLANA_PUBLIC_ADDRESS=your_solana_base58_address_here

# GitHub Token for the Recruiter Agent (public_repo scope)
GITHUB_TOKEN=ghp_your_github_token_here

# RPC Endpoints (Optional, for better performance)
RPC_ETHEREUM=https://cloudflare-eth.com
RPC_ARBITRUM=https://arb1.arbitrum.io/rpc
RPC_OPTIMISM=https://mainnet.optimism.io
RPC_BASE=https://mainnet.base.org
RPC_POLYGON=https://polygon-rpc.com
